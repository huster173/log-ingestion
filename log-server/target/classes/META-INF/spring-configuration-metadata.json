      "sourceType": "com.logingestion.server.config.ServerProperties$Batch",
      "defaultValue": 200
    },
    {
      "name": "log.server.batch.processor-threads",
      "type": "java.lang.Integer",
      "description": "Số worker thread xử lý batch song song",
      "sourceType": "com.logingestion.server.config.ServerProperties$Batch",
      "defaultValue": 4
    },
    {
      "name": "log.server.batch.size",
