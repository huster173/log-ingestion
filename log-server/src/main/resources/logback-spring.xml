<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Console appender với pattern rõ ràng -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %-30logger{30} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- Log ra file (tùy chọn) -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/log-server.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/log-server.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>7</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %-30logger{30} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Giảm noise từ thư viện ngoài -->
    <logger name="com.zaxxer.hikari"              level="WARN"/>
    <logger name="org.h2"                         level="WARN"/>
    <logger name="org.springframework"            level="WARN"/>
    <logger name="org.springframework.web"        level="INFO"/>
    <logger name="org.springframework.boot"       level="INFO"/>
    <logger name="org.springframework.scheduling" level="WARN"/>

    <!-- Application logs -->
    <logger name="com.logingestion" level="INFO"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

</configuration>
