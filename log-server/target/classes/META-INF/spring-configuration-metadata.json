      "sourceType": "com.logingestion.server.config.ServerProperties$Retry",
      "defaultValue": 2000
    },
    {
      "name": "log.server.retry.max-retries",
      "type": "java.lang.Integer",
      "description": "Số lần retry tối đa khi DB insert lỗi",
      "sourceType": "com.logingestion.server.config.ServerProperties$Retry",
      "defaultValue": 3
    },
    {
      "name": "log.server.stats.interval-ms",
      "type": "java.lang.Long",
      "description": "Khoảng thời gian giữa các lần in stats (ms)",
